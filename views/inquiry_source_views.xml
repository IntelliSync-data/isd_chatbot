<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inquiry Source List View -->
    <record id="view_inquiry_source_list" model="ir.ui.view">
        <field name="name">inquiry.source.list</field>
        <field name="model">inquiry.source</field>
        <field name="arch" type="xml">
            <list string="Inquiry Sources" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Inquiry Source Form View -->
    <record id="view_inquiry_source_form" model="ir.ui.view">
        <field name="name">inquiry.source.form</field>
        <field name="model">inquiry.source</field>
        <field name="arch" type="xml">
            <form string="Inquiry Source">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Inquiry Source Action -->
    <record id="action_inquiry_source" model="ir.actions.act_window">
        <field name="name">Inquiry Sources</field>
        <field name="res_model">inquiry.source</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first inquiry source
            </p>
            <p>
                Define different sources for customer inquiries such as Zalo, Facebook, Website, etc.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_inquiry_source"
              name="Inquiry Sources"
              parent="menu_chatbot_config"
              action="action_inquiry_source"
              sequence="30"/>
</odoo>
