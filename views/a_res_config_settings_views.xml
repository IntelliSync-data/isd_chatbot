<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit from the base settings form -->
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.isd_chatbot</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="10"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Add our app section to the form -->
            <xpath expr="//form" position="inside">
                <app data-string="Chatbot" string="Chatbot" name="isd_chatbot">
                    <!-- Response Settings Section -->
                    <block title="Response Settings" id="chatbot_response_settings">
                        <setting string="Default Message" help="Message when no question pattern matches">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="chatbot_default_message" class="w-100" placeholder="Enter default message..."/>
                                </div>
                            </div>
                        </setting>
                        
                        <setting string="Response Type" help="How to handle when no question pattern matches">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="chatbot_response_type" widget="radio" options="{'horizontal': true}"/>
                                </div>
                            </div>
                        </setting>
                        
                        <setting string="Prompt Message" help="Guidance message for prompt mode" invisible="chatbot_response_type != 'prompt'">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="chatbot_prompt_message" class="w-100" placeholder="Enter prompt message..."/>
                                </div>
                            </div>
                        </setting>
                        
                        <setting string="End Message" help="Message shown when conversation ends (after collecting complete information)">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="chatbot_end_message" class="w-100" placeholder="Enter end message..."/>
                                </div>
                            </div>
                        </setting>

                        <setting string="Missing Contact Message" help="Message shown when user submits information without email or phone">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="chatbot_missing_contact_message" class="w-100" placeholder="Enter missing contact message..."/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    
                    <!-- OpenAI API Settings Section -->
                    <block title="OpenAI API Settings" id="chatbot_openai_settings">
                        <setting string="Enable OpenAI" help="Use OpenAI API for analyzing customer inquiries">
                            <field name="chatbot_openai_enabled"/>
                        </setting>
                        
                        <setting string="OpenAI Model" help="Select which OpenAI model to use for analysis" invisible="chatbot_openai_enabled == False">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="chatbot_openai_model"/>
                                </div>
                            </div>
                        </setting>
                        
                        <setting string="OpenAI API Key" help="Your OpenAI API key for authentication (stored securely as system parameter)" invisible="chatbot_openai_enabled == False">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="chatbot_openai_api_key" password="True"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    
                    <!-- NLP Settings Section -->
                    <block title="NLP Settings" id="chatbot_nlp_settings">
                        <setting string="Language Model" help="spaCy language model for question matching">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="chatbot_language_model"/>
                                </div>
                            </div>
                        </setting>
                        
                        <setting string="Similarity Threshold" help="Minimum similarity score required to match a pattern (between 0 and 1)">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="chatbot_threshold"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <!-- CORS Settings -->
                    <block title="Embedded Widget (CORS)" id="chatbot_cors_settings">
                        <setting string="Allowed Origins" help="Danh sách domain được phép nhúng chatbot, cách nhau bằng dấu phẩy. Ví dụ: https://abc.com, https://sub.xyz.com">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="chatbot_cors_origins" class="w-100" placeholder="https://abc.com, https://sub.xyz.com"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <!-- Widget Contact Buttons -->
                    <block title="Widget Contact Buttons" id="chatbot_widget_contacts">
                        <!-- General -->
                        <setting string="General" help="Toggle and Chat button icons and background colors">
                            <div class="content-group">
                                <div class="row mt8">
                                    <div class="col-6">
                                        <label for="chatbot_widget_icon_toggle" string="Toggle Icon"/>
                                        <field name="chatbot_widget_icon_toggle" widget="many2one_avatar" domain="[('mimetype', 'like', 'image/')]"/>
                                    </div>
                                    <div class="col-6">
                                        <label for="chatbot_widget_icon_chat" string="Chat Icon"/>
                                        <field name="chatbot_widget_icon_chat" widget="many2one_avatar" domain="[('mimetype', 'like', 'image/')]"/>
                                    </div>
                                </div>
                                <div class="row mt8">
                                    <div class="col-6">
                                        <label for="chatbot_widget_bg_toggle" string="Toggle BG Color"/>
                                        <field name="chatbot_widget_bg_toggle" widget="color" placeholder="#875a7b"/>
                                    </div>
                                    <div class="col-6">
                                        <label for="chatbot_widget_bg_chat" string="Chat BG Color"/>
                                        <field name="chatbot_widget_bg_chat" widget="color" placeholder="#875a7b"/>
                                    </div>
                                </div>
                            </div>
                        </setting>

                        <!-- Phone -->
                        <setting string="Phone" help="Phone button settings (leave phone number empty to hide)">
                            <div class="content-group">
                                <div class="row mt8">
                                    <div class="col-4">
                                        <label for="chatbot_widget_phone" string="Phone Number"/>
                                        <field name="chatbot_widget_phone" placeholder="+84901234567"/>
                                    </div>
                                    <div class="col-4">
                                        <label for="chatbot_widget_icon_phone" string="Phone Icon"/>
                                        <field name="chatbot_widget_icon_phone" widget="many2one_avatar" domain="[('mimetype', 'like', 'image/')]"/>
                                    </div>
                                    <div class="col-4">
                                        <label for="chatbot_widget_bg_phone" string="Phone BG Color"/>
                                        <field name="chatbot_widget_bg_phone" widget="color" placeholder="#25D366"/>
                                    </div>
                                </div>
                            </div>
                        </setting>

                        <!-- Zalo -->
                        <setting string="Zalo" help="Zalo button settings (leave link empty to hide)">
                            <div class="content-group">
                                <div class="row mt8">
                                    <div class="col-4">
                                        <label for="chatbot_widget_zalo_link" string="Zalo Link"/>
                                        <field name="chatbot_widget_zalo_link" placeholder="https://zalo.me/xxx"/>
                                    </div>
                                    <div class="col-4">
                                        <label for="chatbot_widget_icon_zalo" string="Zalo Icon"/>
                                        <field name="chatbot_widget_icon_zalo" widget="many2one_avatar" domain="[('mimetype', 'like', 'image/')]"/>
                                    </div>
                                    <div class="col-4">
                                        <label for="chatbot_widget_bg_zalo" string="Zalo BG Color"/>
                                        <field name="chatbot_widget_bg_zalo" widget="color" placeholder="#0068FF"/>
                                    </div>
                                </div>
                            </div>
                        </setting>

                        <!-- Messenger -->
                        <setting string="Messenger" help="Messenger button settings (leave link empty to hide)">
                            <div class="content-group">
                                <div class="row mt8">
                                    <div class="col-4">
                                        <label for="chatbot_widget_messenger_link" string="Messenger Link"/>
                                        <field name="chatbot_widget_messenger_link" placeholder="https://m.me/xxx"/>
                                    </div>
                                    <div class="col-4">
                                        <label for="chatbot_widget_icon_messenger" string="Messenger Icon"/>
                                        <field name="chatbot_widget_icon_messenger" widget="many2one_avatar" domain="[('mimetype', 'like', 'image/')]"/>
                                    </div>
                                    <div class="col-4">
                                        <label for="chatbot_widget_bg_messenger" string="Messenger BG Color"/>
                                        <field name="chatbot_widget_bg_messenger" widget="color" placeholder="#0084FF"/>
                                    </div>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <!-- Partner Integration Settings Section -->
                    <block title="Partner Integration Settings" id="chatbot_partner_integration_settings">
                        <setting string="Zalo OA App Id" help="Your Zalo OA App ID for authentication">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="chatbot_zalo_oa_app_id"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Zalo OA API Secret Key" help="Your Zalo OA API secret key for authentication">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="chatbot_zalo_oa_secret_key" password="True"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Zalo OA API Token" help="Your Zalo OA API token for authentication">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="chatbot_zalo_oa_api_token" password="True"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Zalo OA API Refresh Token" help="Your Zalo OA API refresh token for authentication">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="chatbot_zalo_oa_api_refresh_token" password="True"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <!-- Chatbot Settings Menu Action -->
    <record id="action_chatbot_configuration" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'isd_chatbot', 'bin_size': False}</field>
    </record>
</odoo>
