<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Chatbot Conversation Tree View (without explicit type) -->
    <record id="view_chatbot_conversation_list" model="ir.ui.view">
        <field name="name">chatbot.conversation.list</field>
        <field name="model">chatbot.conversation</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="Chatbot Conversations">
                <field name="session_id"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="total_messages"/>
                <field name="status"/>
                <field name="user_ip"/>
                <field name="customer_inquiry_id"/>
            </list>
        </field>
    </record>

    <!-- Chatbot Conversation Form View -->
    <record id="view_chatbot_conversation_form" model="ir.ui.view">
        <field name="name">chatbot.conversation.form</field>
        <field name="model">chatbot.conversation</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Chatbot Conversation">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="session_id"/>
                        </h1>
                        <h3>
                            <field name="total_messages"/> messages
                        </h3>
                    </div>
                    <group>
                        <group string="Conversation Info">
                            <field name="start_time"/>
                            <field name="end_time"/>
                            <field name="status"/>
                        </group>
                        <group string="User Info">
                            <field name="user_ip"/>
                            <field name="customer_inquiry_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Messages" name="messages">
                            <field name="message_ids" nolabel="1">
                                <list string="Conversation Messages" create="false" delete="false">
                                    <field name="timestamp"/>
                                    <field name="message_type" widget="badge" decoration-info="message_type=='user'" decoration-success="message_type=='bot'"/>
                                    <field name="content"/>
                                    <field name="response_type"/>
                                    <field name="matched_config"/>
                                    <field name="similarity_score"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for Chatbot Conversations -->
    <record id="action_chatbot_conversation" model="ir.actions.act_window">
        <field name="name">Conversations</field>
        <field name="res_model">chatbot.conversation</field>
        <field name="view_mode">list,form</field>
    </record>


</odoo>
