<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Customer Inquiry List View -->
    <record id="view_customer_inquiry_list" model="ir.ui.view">
        <field name="name">customer.inquiry.list</field>
        <field name="model">customer.inquiry</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <list string="Customer Inquiries" decoration-info="state=='new'" decoration-success="state=='booked'">
                <field name="create_date"/>
                <field name="source_id" optional="show"/>
                <field name="conversation_session_id" optional="show"/>
                <field name="message" optional="show"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="consultation_datetime"/>
                <field name="state" widget="badge" decoration-info="state=='new'" decoration-warning="state=='saved_to_crm'" decoration-success="state=='booked'"/>
                <field name="assigned_user_id"/>
                <field name="crm_lead_name"/>
                <button name="action_analyze_message" type="object" string="Analyze"
                        class="btn-info" invisible="not message or analyzed or source_id.code == 'manual'"/>
                <button name="action_save_to_crm" type="object" string="Save to CRM"
                        class="btn-primary" invisible="crm_lead_id or (source_id.code == 'chatbot' and not analyzed)"/>
                <button name="action_add_datetime" type="object" string="Add Datetime"
                        class="btn-warning" invisible="consultation_datetime or (source_id.code == 'chatbot' and not analyzed)"/>
                <button name="action_booking" type="object" string="Booking"
                        class="btn-success" invisible="not consultation_datetime or (source_id.code == 'chatbot' and not analyzed)"/>
                <button name="action_invite_user" type="object" string="Invite User" class="btn-secondary"
                        invisible="not can_invite_user or invite_button_text == 'Resend Invite' or (source_id.code == 'chatbot' and not analyzed)"/>
                <button name="action_invite_user" type="object" string="Resend Invite" class="btn-warning"
                        invisible="not can_invite_user or invite_button_text != 'Resend Invite' or (source_id.code == 'chatbot' and not analyzed)"/>
                <field name="analyzed" invisible="1" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Customer Inquiry Form View -->
    <record id="view_customer_inquiry_form" model="ir.ui.view">
        <field name="name">customer.inquiry.form</field>
        <field name="model">customer.inquiry</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Customer Inquiry" chatter_position="false">
                <header>
                    <button name="action_analyze_message" type="object" string="Analyze"
                            class="btn-info" invisible="not message or analyzed or source_id.code == 'manual'"/>
                    <button name="action_save_to_crm" type="object" string="Save to CRM"
                            class="btn-primary" invisible="crm_lead_id or (source_id.code == 'chatbot' and not analyzed)"/>
                    <button name="action_add_datetime" type="object" string="Add Datetime"
                            class="btn-warning" invisible="consultation_datetime or (source_id.code == 'chatbot' and not analyzed)"/>
                    <button name="action_booking" type="object" string="Booking"
                            class="btn-success" invisible="not consultation_datetime or (source_id.code == 'chatbot' and not analyzed)"/>
                    <button name="action_invite_user" type="object" string="Invite User"
                            class="btn-secondary" invisible="not can_invite_user or invite_button_text == 'Resend Invite' or (source_id.code == 'chatbot' and not analyzed)"/>
                    <button name="action_invite_user" type="object" string="Resend Invite"
                            class="btn-warning" invisible="not can_invite_user or invite_button_text != 'Resend Invite' or (source_id.code == 'chatbot' and not analyzed)"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,saved_to_crm,booked"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Customer Name"/>
                        </h1>
                        <h3 invisible="not crm_lead_id">
                            <span class="badge badge-success" title="Has CRM Lead">CRM Lead Created</span>
                        </h3>
                        <h3 invisible="not calendar_event_id">
                            <span class="badge badge-primary" title="Has Calendar Event">Meeting Scheduled</span>
                        </h3>
                    </div>
                    
                    <group string="Message" invisible="not message">
                        <field name="message" widget="text" nolabel="1" readonly="source_id.code == 'chatbot'"/>
                        <div class="alert alert-info" role="alert" invisible="not analyzed">
                            Analyzed on: <field name="analysis_date" readonly="1" nolabel="1"/>
                        </div>
                    </group>
                    
                    <notebook>
                        <page string="Customer Information" name="customer_info">
                            <group>
                                <group string="Contact Information">
                                    <!-- name đã được hiển thị trong tiêu đề -->
                                    <field name="email" widget="email"/>
                                    <field name="phone" widget="phone"/>
                                    <field name="consultation_datetime"/>
                                </group>
                            </group>
                            <group>
                                <group string="System">
                                    <field name="source_id"/>
                                    <field name="state" readonly="1" decoration-info="state=='new'" decoration-warning="state=='saved_to_crm'" decoration-success="state=='booked'"/>
                                    <field name="assigned_user_id"/>
                                    <field name="create_date" readonly="1"/>
                                </group>
                            </group>
                            <group string="Survey &amp; Student Integration">
                                <group>
                                    <field name="survey_user_input_id" readonly="1" options="{'no_create': True, 'no_open': False}"/>
                                    <field name="student_id" readonly="1" options="{'no_create': True, 'no_open': False}"/>
                                </group>
                            </group>
                        </page>
                        <page string="Analysis Results" name="analysis_tab" invisible="not analyzed">
                            <group>
                                <field name="analyzed_message" readonly="1" widget="text" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Conversation Details" name="conversation_tab" invisible="not conversation_id">
                            <group>
                                <group string="Conversation Information">
                                    <field name="conversation_id" readonly="1" options="{'no_create': True, 'no_open': False}"/>
                                    <field name="conversation_session_id" readonly="1"/>
                                    <field name="conversation_total_messages" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                    

                    
                    <group string="Analysis Log" invisible="1">
                        <field name="analysis_log" widget="text" nolabel="1" readonly="1"/>
                    </group>
                    <group string="Related Records" invisible="1">
                        <group>
                            <field name="crm_lead_id" readonly="1"/>
                            <field name="crm_lead_name" readonly="1"/>
                        </group>
                        <group>
                            <field name="calendar_event_id" readonly="1"/>
                            <field name="calendar_event_name" readonly="1"/>
                        </group>
                    </group>
                    
                    <!-- Invisible fields for computations -->
                    <field name="can_invite_user" invisible="1"/>
                    <field name="invite_button_text" invisible="1"/>
                    <field name="analyzed" invisible="1"/>
                </sheet>
                <!-- Đã xóa phần chatter -->
            </form>
        </field>
    </record>

    <!-- Customer Inquiry Datetime Form View -->
    <record id="view_customer_inquiry_datetime_form" model="ir.ui.view">
        <field name="name">customer.inquiry.datetime.form</field>
        <field name="model">customer.inquiry</field>
        <field name="arch" type="xml">
            <form string="Set Consultation Date and Time">
                <group>
                    <field name="name"/>
                    <field name="email"/>
                    <field name="consultation_datetime"/>
                </group>
                <footer>
                    <button string="Save" type="object" name="action_save" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Customer Inquiry Search View -->
    <record id="view_customer_inquiry_search" model="ir.ui.view">
        <field name="name">customer.inquiry.search</field>
        <field name="model">customer.inquiry</field>
        <field name="arch" type="xml">
            <search string="Customer Inquiries">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="assigned_user_id"/>
                <filter string="New" name="filter_new" domain="[('state', '=', 'new')]"/>
                <filter string="Saved to CRM" name="filter_saved" domain="[('state', '=', 'saved_to_crm')]"/>
                <filter string="Booked" name="filter_booked" domain="[('state', '=', 'booked')]"/>
                <separator/>
                <filter string="My Inquiries" name="filter_my" domain="[('assigned_user_id', '=', uid)]"/>
                <separator/>
                <filter string="Analyzed" name="filter_analyzed" domain="[('analyzed', '=', True)]"/>
                <filter string="Not Analyzed" name="filter_not_analyzed" domain="[('analyzed', '=', False)]"/>
                <separator/>
                <filter string="Today" name="filter_today" domain="[('create_date', '>=', datetime.datetime.combine(context_today(), datetime.time(0,0,0)))]"/>
                <filter string="This Week" name="filter_week" domain="[('create_date', '>=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Assigned User" name="group_user" context="{'group_by': 'assigned_user_id'}"/>
                    <filter string="Creation Date" name="group_date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Customer Inquiry Action - Đơn giản hóa cấu hình -->
    <record id="action_customer_inquiry" model="ir.actions.act_window">
        <field name="name">Customer Inquiries</field>
        <field name="res_model">customer.inquiry</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_customer_inquiry_list"/>
        <field name="search_view_id" ref="view_customer_inquiry_search"/>
        <field name="context">{
            "search_default_filter_new": 1, 
            "default_source": "manual",
            "default_assigned_user_id": uid
        }</field>
        <field name="views">
            [(ref('view_customer_inquiry_list'), 'list'), 
             (ref('view_customer_inquiry_form'), 'form')]
        </field>
    </record>
</odoo>
