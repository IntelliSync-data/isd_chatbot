<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Webhook Log List View -->
    <record id="view_webhook_log_tree" model="ir.ui.view">
        <field name="name">chatbot.webhook.log.list</field>
        <field name="model">chatbot.webhook.log</field>
        <field name="arch" type="xml">
            <list string="Webhook Logs" default_order="create_date desc">
                <field name="webhook_id"/>
                <field name="http_method" widget="badge"/>
                <field name="status" widget="badge" 
                       decoration-success="status == 'processed'"
                       decoration-info="status == 'received'"
                       decoration-danger="status == 'error'"
                       decoration-muted="status == 'ignored'"/>
                <field name="webhook_type"/>
                <field name="event_type"/>
                <field name="source_ip"/>
                <field name="payload_size" widget="integer"/>
                <field name="created_at"/>
                <field name="processed_at"/>
            </list>
        </field>
    </record>

    <!-- Webhook Log Form View -->
    <record id="view_webhook_log_form" model="ir.ui.view">
        <field name="name">chatbot.webhook.log.form</field>
        <field name="model">chatbot.webhook.log</field>
        <field name="arch" type="xml">
            <form string="Webhook Log">
                <header>
                    <button name="action_mark_processed" string="Mark as Processed"
                            type="object" class="btn-primary"
                            invisible="status in ['processed', 'error']"/>
                    <button name="action_mark_error" string="Mark as Error"
                            type="object" class="btn-warning"
                            invisible="status == 'error'"/>
                    <button name="action_reprocess" string="Reset for Reprocessing"
                            type="object" class="btn-secondary"
                            invisible="status == 'received'"/>
                    <field name="status" widget="statusbar" 
                           statusbar_visible="received,processed,error"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="webhook_id" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group name="webhook_info" string="Request Information">
                            <field name="http_method"/>
                            <field name="full_url"/>
                            <field name="webhook_type"/>
                            <field name="event_type"/>
                            <field name="payload_size" widget="integer"/>
                            <field name="source_ip"/>
                        </group>
                        <group name="timestamps" string="Timestamps">
                            <field name="created_at"/>
                            <field name="updated_at"/>
                            <field name="processed_at"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Request Body" name="request_body">
                            <group>
                                <field name="json_data_formatted" widget="text" nolabel="1"
                                       placeholder="Formatted request body will appear here..."/>
                            </group>
                        </page>
                        <page string="Raw Body" name="raw_body">
                            <group>
                                <field name="json_data" widget="text" nolabel="1"
                                       placeholder="Raw request body will appear here..."/>
                            </group>
                        </page>
                        <page string="Query Parameters" name="query_params">
                            <group>
                                <field name="query_params" widget="text" nolabel="1"
                                       placeholder="Query parameters will appear here..."/>
                            </group>
                        </page>
                        <page string="Headers" name="headers">
                            <group>
                                <field name="request_headers" widget="text" nolabel="1"
                                       placeholder="Request headers will appear here..."/>
                                <field name="user_agent" widget="text"
                                       placeholder="User agent will appear here..."/>
                            </group>
                        </page>
                        <page string="Processing" name="processing">
                            <group>
                                <field name="processing_notes" widget="text" 
                                       placeholder="Processing notes..."/>
                                <field name="error_message" widget="text"
                                       placeholder="Error details will appear here..."
                                       invisible="not error_message"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Webhook Log Search View -->
    <record id="view_webhook_log_search" model="ir.ui.view">
        <field name="name">chatbot.webhook.log.search</field>
        <field name="model">chatbot.webhook.log</field>
        <field name="arch" type="xml">
            <search string="Search Webhook Logs">
                <field name="webhook_id"/>
                <field name="http_method"/>
                <field name="webhook_type"/>
                <field name="event_type"/>
                <field name="source_ip"/>
                <field name="full_url"/>
                <field name="json_data"/>
                
                <filter string="Today" name="filter_today"
                        domain="[('created_at', '>=', context_today())]"/>
                <filter string="This Week" name="filter_week"
                        domain="[('created_at', '>=', (context_today() - datetime.timedelta(days=7)))]"/>
                <filter string="This Month" name="filter_month"
                        domain="[('created_at', '>=', (context_today() - datetime.timedelta(days=30)))]"/>
                
                <separator/>
                <filter string="GET" name="filter_get"
                        domain="[('http_method', '=', 'GET')]"/>
                <filter string="POST" name="filter_post"
                        domain="[('http_method', '=', 'POST')]"/>
                <filter string="PUT" name="filter_put"
                        domain="[('http_method', '=', 'PUT')]"/>
                <filter string="DELETE" name="filter_delete"
                        domain="[('http_method', '=', 'DELETE')]"/>
                <filter string="PATCH" name="filter_patch"
                        domain="[('http_method', '=', 'PATCH')]"/>
                
                <separator/>
                <filter string="Received" name="filter_received"
                        domain="[('status', '=', 'received')]"/>
                <filter string="Processed" name="filter_processed"
                        domain="[('status', '=', 'processed')]"/>
                <filter string="Error" name="filter_error"
                        domain="[('status', '=', 'error')]"/>
                <filter string="Ignored" name="filter_ignored"
                        domain="[('status', '=', 'ignored')]"/>
                
                <group expand="0" string="Group By">
                    <filter string="HTTP Method" name="group_method" context="{'group_by': 'http_method'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Webhook Type" name="group_webhook_type" context="{'group_by': 'webhook_type'}"/>
                    <filter string="Event Type" name="group_event_type" context="{'group_by': 'event_type'}"/>
                    <filter string="Source IP" name="group_source_ip" context="{'group_by': 'source_ip'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'created_at:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Webhook Log Action -->
    <record id="action_webhook_log" model="ir.actions.act_window">
        <field name="name">Webhook Logs</field>
        <field name="res_model">chatbot.webhook.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{
            'search_default_filter_week': 1,
            'search_default_group_status': 1
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No webhook logs found!
            </p>
            <p>
                Webhook logs will appear here when external services send data to your webhook endpoint:
                <br/>
                <strong>/isd_chatbot/webhook</strong>
            </p>
        </field>
    </record>

    <!-- Webhook Statistics Dashboard Action -->
    <record id="action_webhook_stats" model="ir.actions.act_window">
        <field name="name">Webhook Statistics</field>
        <field name="res_model">chatbot.webhook.log</field>
        <field name="view_mode">graph,pivot</field>
        <field name="context">{
            'search_default_filter_month': 1
        }</field>
    </record>

    <!-- Graph View for Statistics -->
    <record id="view_webhook_log_graph" model="ir.ui.view">
        <field name="name">chatbot.webhook.log.graph</field>
        <field name="model">chatbot.webhook.log</field>
        <field name="arch" type="xml">
            <graph string="Webhook Statistics" type="bar">
                <field name="created_at" type="row" interval="day"/>
                <field name="status" type="col"/>
            </graph>
        </field>
    </record>

    <!-- Pivot View for Statistics -->
    <record id="view_webhook_log_pivot" model="ir.ui.view">
        <field name="name">chatbot.webhook.log.pivot</field>
        <field name="model">chatbot.webhook.log</field>
        <field name="arch" type="xml">
            <pivot string="Webhook Analysis">
                <field name="created_at" type="row" interval="day"/>
                <field name="status" type="col"/>
                <field name="payload_size" type="measure"/>
            </pivot>
        </field>
    </record>
</odoo>