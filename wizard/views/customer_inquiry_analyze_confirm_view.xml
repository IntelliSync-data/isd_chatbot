<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_customer_inquiry_analyze_confirm_form" model="ir.ui.view">
        <field name="name">customer.inquiry.analyze.confirm.form</field>
        <field name="model">customer.inquiry.analyze.confirm</field>
        <field name="arch" type="xml">
            <form string="Xác nhận phân tích lại">
                <sheet>
                    <div class="alert alert-warning" role="alert">
                        Inquiry này đã được phân tích trước đó vào lúc: <field name="analysis_date" readonly="1"/>
                        <br/>
                        Các thông tin hiện tại sẽ bị ghi đè nếu phát hiện dữ liệu mới từ tin nhắn.
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="email" readonly="1"/>
                        </group>
                        <group>
                            <field name="phone" readonly="1"/>
                            <field name="consultation_datetime" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="message" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Phân tích lại" name="action_confirm" type="object" class="btn-primary"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
