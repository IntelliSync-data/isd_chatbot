<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cron job to cleanup old webhook logs -->
    <record id="ir_cron_webhook_cleanup" model="ir.cron">
        <field name="name">Chatbot: Cleanup Old Webhook Logs</field>
        <field name="model_id" ref="model_chatbot_webhook_log"/>
        <field name="state">code</field>
        <field name="code">model.cleanup_old_webhooks(days=30)</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
        <field name="user_id" ref="base.user_admin"/>
    </record>
</odoo>